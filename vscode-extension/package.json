{
  "name": "openmv",
  "displayName": "OpenMV",
  "description": "OpenMV VS Code Extension",
  "version": "2.1.0",
  "publisher": "openmv",
  "repository": {
    "type": "git",
    "url": "https://github.com/SingTown/openmv-mcp.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openmv.connect",
        "title": "Connect",
        "category": "OpenMV"
      },
      {
        "command": "openmv.disconnect",
        "title": "Disconnect",
        "category": "OpenMV"
      },
      {
        "command": "openmv.runScript",
        "title": "Run Script",
        "category": "OpenMV"
      },
      {
        "command": "openmv.stopScript",
        "title": "Stop Script",
        "category": "OpenMV"
      },
      {
        "command": "openmv.drive",
        "title": "Open Camera Drive",
        "category": "OpenMV"
      },
      {
        "command": "openmv.selectFrameSaveFolder",
        "title": "Select Frame Save Folder",
        "category": "OpenMV",
        "icon": "$(folder)"
      },
      {
        "command": "openmv.saveFrame",
        "title": "Save Frame",
        "category": "OpenMV",
        "icon": "$(save)"
      },
      {
        "command": "openmv.update",
        "title": "Update Firmware",
        "category": "OpenMV"
      },
      {
        "command": "openmv.firmware",
        "title": "Flash Custom Firmware...",
        "category": "OpenMV"
      },
      {
        "command": "openmv.repair",
        "title": "Repair Firmware...",
        "category": "OpenMV"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openmv-frameActivitybar",
          "title": "OpenMV",
          "icon": "media/camera.svg"
        }
      ]
    },
    "views": {
      "openmv-frameActivitybar": [
        {
          "id": "openmv-frameView",
          "name": "Frame",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "openmv.selectFrameSaveFolder",
          "when": "view == openmv-frameView",
          "group": "navigation@1"
        },
        {
          "command": "openmv.saveFrame",
          "when": "view == openmv-frameView",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "pnpm run typecheck && node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/ && pnpm run typecheck",
    "package": "vsce package",
    "package:darwin-x64": "vsce package --no-dependencies --target darwin-x64 --ignoreFile .vscodeignore.darwin",
    "package:darwin-arm64": "vsce package --no-dependencies --target darwin-arm64 --ignoreFile .vscodeignore.darwin",
    "package:win32-x64": "vsce package --no-dependencies --target win32-x64 --ignoreFile .vscodeignore.win32",
    "package:win32-arm64": "vsce package --no-dependencies --target win32-arm64 --ignoreFile .vscodeignore.win32",
    "package:linux-x64": "vsce package --no-dependencies --target linux-x64 --ignoreFile .vscodeignore.linux-x64",
    "package:linux-arm64": "vsce package --no-dependencies --target linux-arm64 --ignoreFile .vscodeignore.linux-arm64",
    "package:all": "pnpm run package:darwin-x64 && pnpm run package:darwin-arm64 && pnpm run package:win32-x64 && pnpm run package:win32-arm64 && pnpm run package:linux-x64 && pnpm run package:linux-arm64"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.17",
    "execa": "^9.6.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
